{
  "name": "parivesh-backend",
  "version": "1.0.0",
  "description": "PARIVESH 3.0 — Backend API Server",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "jest --runInBand",
    "migrate": "npx sequelize-cli db:migrate",
